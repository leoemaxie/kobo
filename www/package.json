{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write:translations": "docusaurus write-translations",
    "write:heading": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "gen:docs": "docusaurus gen-api-docs all && node -e \"const fs = require('fs'); const path = require('path'); const dir = 'docs/api'; fs.readdirSync(dir).filter(f => f.endsWith('.tag.mdx')).forEach(f => { const p = path.join(dir, f); fs.writeFileSync(p, fs.readFileSync(p, 'utf8').replace('@docusaurus/theme-common', '@docusaurus/theme-common/internal')); });\"",
    "clean:docs": "docusaurus clean-api-docs all"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-openapi-docs": "^5.1.0",
    "docusaurus-theme-openapi-docs": "^5.1.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/react": "^19.2.17",
    "jimp": "^1.6.1",
    "typescript": "~6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}