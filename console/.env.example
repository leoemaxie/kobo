# PostgreSQL connection string (Drizzle ORM)
DATABASE_URL="postgres://username:password@localhost:5432/kobo"

# URL to the Kobo documentation (used in the dashboard header)
PUBLIC_DOCS_URL="https://docs.kobo.dev"

# Unsend API key for transactional emails (verification, alerts, billing)
UNSEND_API_KEY="your_unsend_api_key_here"

# (Optional) Override the Unsend API URL if using a specific region or mock server
UNSEND_API_URL="https://api.unosend.com/v1/emails"
